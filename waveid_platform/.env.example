# WaveID environment variables (copy to .env and fill in locally)
# Never commit .env to git.

# Required for protected routes in production
WAVEID_API_KEY=

# Set to true to require API key on ingest-track (reset always requires key when API key is set)
WAVEID_REQUIRE_API_KEY=false

# Preserve catalogue/index between server restarts (recommended for production)
WAVEID_RESET_ON_STARTUP=true

# Rate limits (slowapi format)
WAVEID_RATE_LIMIT_DEFAULT=100/minute
WAVEID_RATE_LIMIT_AUTH=5/15minutes

# Upload limits
WAVEID_MAX_UPLOAD_MB=50
WAVEID_MAX_DURATION_SECONDS=600
WAVEID_MAX_FILENAME_LENGTH=255

# Optional CORS (comma-separated origins, leave empty for same-origin only)
WAVEID_CORS_ORIGINS=

# External Chromaprint binary path (evaluation scripts only)
FPCALC=fpcalc
