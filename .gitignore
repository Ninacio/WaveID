datasets/
*.wav
*.mp3

# Virtual environment (never commit)
.venv/
venv/

# Dissertation and documentation (not for the code repo)
Dissertation/

# Generated contrastive training data and large embedding arrays (>100 MB, GitHub limit)
**/contrastive_pairs/*.npy
waveid_platform/data/embeddings/

# Python cache/build artifacts
**/__pycache__/
*.py[cod]

# Local index/runtime state (regenerated by app)
waveid_platform/data/index/embeddings.npy
waveid_platform/data/index/embedding_ids.json
waveid_platform/data/index/catalogue.json

# Runtime query/reference artefacts (keep folders via .gitkeep)
waveid_platform/data/query/*
!waveid_platform/data/query/.gitkeep
waveid_platform/data/reference/*
!waveid_platform/data/reference/.gitkeep
